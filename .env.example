# ============================================================
# BIOCore 环境配置文件
# 复制此文件为 .env 并根据实际环境修改
# ============================================================

# ─── 服务器 ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── PLC (S7-200 SMART G2) ─────────────────────────────────
PLC_IP=192.168.2.1
PLC_PORT=102
PLC_RACK=0
PLC_SLOT=1
PLC_HEARTBEAT_TIMEOUT_MS=3000

# ─── InfluxDB ───────────────────────────────────────────────
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=biocore-dev-token
INFLUX_ORG=biocore
INFLUX_BUCKET=fermentation

# ─── SQLite ─────────────────────────────────────────────────
SQLITE_PATH=./data/biocore.db

# ─── 本地AI (Ollama) ───────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ─── 云端AI (可选, 留空则纯本地运行) ───────────────────────
# CLOUD_API_KEY=sk-ant-xxxxxxxx
# CLOUD_API_URL=https://api.anthropic.com
# CLOUD_MODEL=claude-sonnet-4-20250514

# ─── 前端 ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws
