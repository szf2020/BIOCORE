# ============================================================
# BIOCore 环境配置文件
# 复制此文件为 .env 并根据实际环境修改
# ============================================================

# ─── 服务器 ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── PLC (S7-200 SMART G2) ─────────────────────────────────
PLC_IP=192.168.2.1
PLC_PORT=102
PLC_RACK=0
PLC_SLOT=1
PLC_HEARTBEAT_TIMEOUT_MS=3000

# ─── InfluxDB ───────────────────────────────────────────────
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=biocore-dev-token
INFLUX_ORG=biocore
INFLUX_BUCKET=fermentation

# ─── SQLite ─────────────────────────────────────────────────
SQLITE_PATH=./data/biocore.db

# ─── 本地AI (Ollama) ───────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ─── 云端AI (可选, 留空则纯本地运行) ───────────────────────
# CLOUD_API_KEY=sk-ant-xxxxxxxx
# CLOUD_API_URL=https://api.anthropic.com
# CLOUD_MODEL=claude-sonnet-4-20250514

# ─── 前端 ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws

# 顶部面包屑 (按客户/产线定制, 不设则用默认)
NEXT_PUBLIC_FACILITY_NAME=生产车间
NEXT_PUBLIC_LINE_NAME=发酵产线 #1
NEXT_PUBLIC_REACTOR_GROUP_NAME=5L 研发罐组

# ─── Runtime-guard 加固 (T22-T25, Sprint 4 Track A) ─────────
# Node max heap (生产建议 2-4GB)
NODE_OPTIONS=--max-old-space-size=2048
# OOM 触发阈值: 'auto' = 物理 RAM × 20%; 也可填具体 MB 数 (如 1638)
BIOCORE_OOM_THRESHOLD_MB=auto
# 连续 N 次采样超阈值才触发 SIGTERM (默认 3)
BIOCORE_OOM_GRACE_SAMPLES=3
# 崩溃诊断包目录 (Docker 中映射到 host volume)
BIOCORE_DIAGNOSTIC_DUMP_DIR=./crashes
# 保留最近 N 个诊断包 (默认 50)
BIOCORE_DIAGNOSTIC_KEEP_LAST=50

# ─── MOCK_PLC (SP-FX-23) ────────────────────────────────────
# true  → MockPlcClient (内存 mock, 开发/测试/CI, 不需真 PLC)
# false → 真实 snap7 连接 (生产, 需 PLC_IP/PLC_RACK/PLC_SLOT)
# 生产部署前必须确认 = false 或移除该变量。
MOCK_PLC=true

# 真实 PLC 连接参数 (MOCK_PLC=false 时生效)
# PLC_IP: S7-200 SMART 的 IP 地址
# PLC_RACK: 机架号 (S7-200 SMART 固定为 0)
# PLC_SLOT: 插槽号 (S7-200 SMART 固定为 1)
PLC_IP=192.168.1.10
PLC_RACK=0
PLC_SLOT=1

# ─── FUXA_READONLY ──────────────────────────────────────────
# 安全约束: AI / HMI / 外部系统不可直写 PLC, 一律走 BIOCore suggestion → 人工 → engine。
# true (默认): FUXA setDeviceValue 短路, 写企图被日志 warn。
# false: 解锁 FUXA 写 (仅过渡期/特殊调试; 生产严禁)。
FUXA_READONLY=true

# ─── SP-FX-37 生产部署变量 ───────────────────────────────────
# 以下变量为生产环境必填或推荐设置。
# 开发环境可保持默认或留空。

# 数据库路径 (生产 Docker: /app/data/biocore.db)
DATABASE_PATH=./data/biocore.db

# JWT 签名密钥 (生产必须: openssl rand -hex 32)
# 切勿使用默认值！
JWT_SECRET=biocore-dev-secret-change-in-production

# 项目根路径 (Docker: /app; 本地: 项目根目录)
# 用于 backup 命令、脚本定位等
BIOCORE_ROOT=.

# ─── 日志级别 (SP-FX-37) ────────────────────────────────────
# error | warn | info | debug (默认: info)
# 生产建议: warn 或 error (降噪)
LOG_LEVEL=info

# ─── CORS 允许来源 ──────────────────────────────────────────
# 生产: https://your-domain.com
# 留空则使用 Express 默认 (宽松)
CORS_ORIGIN=http://localhost:3000

# ─── Metrics 认证 Token (SP-FX-28) ─────────────────────────
# GET /api/v1/metrics 需要此 token (BIOCORE_METRICS_REQUIRE_AUTH=true 时)
# 生产: openssl rand -hex 16
METRICS_AUTH_TOKEN=

# ─── SMTP 告警邮件 (占位, 待 alert 功能) ────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=biocore-alerts@example.com
# SMTP_PASS=your-smtp-password
