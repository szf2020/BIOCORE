# ============================================================
# BIOCore 环境配置文件
# 复制此文件为 .env 并根据实际环境修改
# ============================================================

# ─── 服务器 ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── PLC (S7-200 SMART G2) ─────────────────────────────────
PLC_IP=192.168.2.1
PLC_PORT=102
PLC_RACK=0
PLC_SLOT=1
PLC_HEARTBEAT_TIMEOUT_MS=3000

# ─── InfluxDB ───────────────────────────────────────────────
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=biocore-dev-token
INFLUX_ORG=biocore
INFLUX_BUCKET=fermentation

# ─── SQLite ─────────────────────────────────────────────────
SQLITE_PATH=./data/biocore.db

# ─── 本地AI (Ollama) ───────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ─── 云端AI (可选, 留空则纯本地运行) ───────────────────────
# CLOUD_API_KEY=sk-ant-xxxxxxxx
# CLOUD_API_URL=https://api.anthropic.com
# CLOUD_MODEL=claude-sonnet-4-20250514

# ─── 前端 ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws

# 顶部面包屑 (按客户/产线定制, 不设则用默认)
NEXT_PUBLIC_FACILITY_NAME=生产车间
NEXT_PUBLIC_LINE_NAME=发酵产线 #1
NEXT_PUBLIC_REACTOR_GROUP_NAME=5L 研发罐组

# ─── Runtime-guard 加固 (T22-T25, Sprint 4 Track A) ─────────
# Node max heap (生产建议 2-4GB)
NODE_OPTIONS=--max-old-space-size=2048
# OOM 触发阈值: 'auto' = 物理 RAM × 20%; 也可填具体 MB 数 (如 1638)
BIOCORE_OOM_THRESHOLD_MB=auto
# 连续 N 次采样超阈值才触发 SIGTERM (默认 3)
BIOCORE_OOM_GRACE_SAMPLES=3
# 崩溃诊断包目录 (Docker 中映射到 host volume)
BIOCORE_DIAGNOSTIC_DUMP_DIR=./crashes
# 保留最近 N 个诊断包 (默认 50)
BIOCORE_DIAGNOSTIC_KEEP_LAST=50

# ─── MOCK_PLC ───────────────────────────────────────────────
# 默认 false (生产安全)。开发演示设 true 跳过 PLC 真连。
# 生产部署前必须确认 = false 或移除该变量。
MOCK_PLC=false

# ─── FUXA_READONLY ──────────────────────────────────────────
# 安全约束: AI / HMI / 外部系统不可直写 PLC, 一律走 BIOCore suggestion → 人工 → engine。
# true (默认): FUXA setDeviceValue 短路, 写企图被日志 warn。
# false: 解锁 FUXA 写 (仅过渡期/特殊调试; 生产严禁)。
FUXA_READONLY=true
