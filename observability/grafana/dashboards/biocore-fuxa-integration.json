{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "FUXA 容器健康",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "palette-classic" },
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"biocore-(fuxa|mosquitto|nginx)\"}[1m])",
          "refId": "A",
          "legendFormat": "{{name}}"
        }
      ],
      "title": "容器 CPU 使用率 (FUXA / mosquitto / nginx)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"biocore-(fuxa|mosquitto|nginx)\"}",
          "refId": "A",
          "legendFormat": "{{name}}"
        }
      ],
      "title": "容器内存使用 (FUXA / mosquitto / nginx)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 9 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "targets": [
        {
          "expr": "max(container_last_seen{name=\"biocore-fuxa\"}) > (time() - 60)",
          "refId": "A",
          "legendFormat": "FUXA"
        }
      ],
      "title": "FUXA 容器存活 (60s 窗口)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 9 },
      "id": 4,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{name=~\"biocore-(fuxa|mosquitto|nginx)\"}[1m])",
          "refId": "A",
          "legendFormat": "{{name}} rx"
        },
        {
          "expr": "rate(container_network_transmit_bytes_total{name=~\"biocore-(fuxa|mosquitto|nginx)\"}[1m])",
          "refId": "B",
          "legendFormat": "{{name}} tx"
        }
      ],
      "title": "容器网络流量",
      "type": "timeseries"
    },
    {
      "type": "row",
      "id": 101,
      "title": "Mosquitto MQTT Broker",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false,
      "panels": []
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue" }] } },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 18 },
      "id": 5,
      "options": { "graphMode": "area", "textMode": "value_and_name" },
      "targets": [
        {
          "expr": "max(mqtt_broker_clients_connected)",
          "refId": "A",
          "legendFormat": "已连接客户端"
        }
      ],
      "title": "MQTT 当前连接数",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 18 },
      "id": 6,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(mqtt_broker_messages_received_total[1m])",
          "refId": "A",
          "legendFormat": "received/s"
        },
        {
          "expr": "rate(mqtt_broker_messages_sent_total[1m])",
          "refId": "B",
          "legendFormat": "sent/s"
        }
      ],
      "title": "MQTT 消息收发率 (msg/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 7,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(mqtt_broker_bytes_received_total[1m])",
          "refId": "A",
          "legendFormat": "bytes_in/s"
        },
        {
          "expr": "rate(mqtt_broker_bytes_sent_total[1m])",
          "refId": "B",
          "legendFormat": "bytes_out/s"
        }
      ],
      "title": "MQTT 字节吞吐",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 8,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "mqtt_broker_subscriptions_count",
          "refId": "A",
          "legendFormat": "subscriptions"
        },
        {
          "expr": "mqtt_broker_retained_messages_count",
          "refId": "B",
          "legendFormat": "retained"
        }
      ],
      "title": "MQTT 订阅数 & retained 消息",
      "type": "timeseries"
    },
    {
      "type": "row",
      "id": 102,
      "title": "Nginx 反向代理",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": false,
      "panels": []
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 9,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(nginx_http_requests_total[1m])",
          "refId": "A",
          "legendFormat": "requests/s"
        }
      ],
      "title": "Nginx 请求速率",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "nginx_connections_active",
          "refId": "A",
          "legendFormat": "active"
        },
        {
          "expr": "nginx_connections_reading",
          "refId": "B",
          "legendFormat": "reading"
        },
        {
          "expr": "nginx_connections_writing",
          "refId": "C",
          "legendFormat": "writing"
        },
        {
          "expr": "nginx_connections_waiting",
          "refId": "D",
          "legendFormat": "waiting"
        }
      ],
      "title": "Nginx 连接状态",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "max": 1,
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 40 },
      "id": 11,
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value_and_name" },
      "targets": [
        {
          "expr": "(rate(nginx_http_requests_total[5m]) - rate(nginx_connections_handled[5m])) / clamp_min(rate(nginx_http_requests_total[5m]), 1)",
          "refId": "A",
          "legendFormat": "nginx 拒绝/失败比"
        }
      ],
      "title": "Nginx 失败比 (handled vs accepted)",
      "description": "nginx stub_status 不直接给 5xx 计数; 失败比 = (accepted - handled) / requests。访问日志中的 5xx 由 Loki/Promtail 链路单独统计。",
      "type": "stat"
    },
    {
      "type": "row",
      "id": 103,
      "title": "BIOCore Server → MQTT 桥",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 46 },
      "collapsed": false,
      "panels": []
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 47 },
      "id": 12,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "biocore_ws_connections",
          "refId": "A",
          "legendFormat": "ws_connections"
        }
      ],
      "title": "BIOCore WS 连接数 (broadcast 源)",
      "description": "BIOCore 每个 ws-server broadcast() 自动 mirror MQTT publish。WS 连接数 + MQTT 发送速率交叉对比可定位桥路是否阻塞。",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 47 },
      "id": 13,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(mqtt_broker_messages_received_total[1m])",
          "refId": "A",
          "legendFormat": "broker_recv/s (含 BIOCore publish)"
        }
      ],
      "title": "MQTT broker 收到的消息率 (近似 BIOCore broadcast 速率)",
      "description": "BIOCore server 是 mosquitto 上游 publish 唯一来源 (W2 阶段)。broker_messages_received_total 上升 = ws-server broadcast 成功转 MQTT。",
      "type": "timeseries"
    }
  ],
