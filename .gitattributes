# 强制 LF 行尾, 跨平台一致
# 历史背景: 此项目跨 Windows/macOS 协作, 早期无 .gitattributes 导致 CRLF 漂移
# 一次性 git add --renormalize . 后所有文本文件归一化为 LF

* text=auto eol=lf

# 显式声明文本类型 (防止误判)
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.mjs      text eol=lf
*.cjs      text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.sql      text eol=lf
*.sh       text eol=lf
*.css      text eol=lf
*.html     text eol=lf
*.txt      text eol=lf
*.env      text eol=lf
.env.*     text eol=lf
Dockerfile text eol=lf

# Windows 专用脚本保留 CRLF (PowerShell 在 Windows 上要求)
*.ps1      text eol=crlf

# 二进制 (绝不归一化)
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.svg      text eol=lf
*.pdf      binary
*.docx     binary
*.xlsx     binary
*.pptx     binary
*.db       binary
*.db-wal   binary
*.db-shm   binary
*.gz       binary
*.zip      binary
*.tar      binary
*.exe      binary
*.dll      binary
*.so       binary
*.dylib    binary
*.node     binary
