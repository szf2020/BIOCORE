{
  "name": "biocore",
  "version": "1.14.0",
  "private": true,
  "description": "BIOCore — 实验室R&D发酵控制平台",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:server": "pnpm --filter @biocore/server run dev",
    "dev:ui": "pnpm --filter @biocore/web-ui run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "db:init": "pnpm --filter @biocore/data-service run db:init",
    "plc:test": "pnpm --filter @biocore/plc-driver run test:connection",
    "soak": "node scripts/soak-test.mjs",
    "soak:short": "SOAK_DURATION_HOURS=1 node scripts/soak-test.mjs",
    "soak:tiny": "SOAK_DURATION_HOURS=0.05 SOAK_BROWSER=false node scripts/soak-test.mjs",
    "healthcheck": "node scripts/healthcheck.mjs",
    "backup": "bash scripts/backup-db.sh",
    "backup:restore": "bash scripts/restore-db.sh",
    "seed:demo": "sqlite3 packages/server/data/biocore.db < scripts/seed-demo.sql",
    "gen:shape-catalog": "tsx scripts/gen-shape-catalog.ts"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "onlyBuiltDependencies": [
      "puppeteer",
      "better-sqlite3",
      "node-snap7"
    ]
  },
  "dependencies": {
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
